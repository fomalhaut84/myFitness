DATABASE_URL="postgresql://user:password@localhost:5432/myfitness"
BASE_URL="http://localhost:4200"
PORT=4200

# Garmin Connect
GARMIN_EMAIL=""
GARMIN_PASSWORD=""

# Cron
SYNC_CRON="0 6,9,12,15,18,21 * * *"
MORNING_REPORT_CRON="0 8 * * *"
EVENING_REPORT_CRON="0 23 * * *"
REPORT_CRON="0 7 * * 1"

# Telegram Bot
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ALLOWED_CHAT_IDS=""

# Claude CLI 절대 경로 (운영 필수). 봇 프로세스가 pm2 delete + start로 시작되면
# login shell profile 미로드로 ~/.local/bin이 PATH에서 누락되어 spawn ENOENT.
# `which claude` 결과를 사용. 미설정/빈문자열이면 PATH 조회 (개발 환경 편의).
# 값 예시 (운영자가 실제 경로로 교체):
# CLAUDE_BIN=/home/user/.local/bin/claude
