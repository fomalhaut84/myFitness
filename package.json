{
  "name": "myfitness",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && npm run build:mcp && npm run build:bot",
    "build:mcp": "esbuild src/mcp/server.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/mcp/server.mjs --external:@modelcontextprotocol/sdk",
    "build:bot": "esbuild src/bot/standalone.ts --bundle --platform=node --target=node20 --outfile=dist/bot/standalone.cjs --alias:@=./src --external:grammy --external:node-cron --external:dotenv --external:@prisma/client --external:@flow-js/garmin-connect",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@flow-js/garmin-connect": "^1.6.16",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.19.3",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "grammy": "^1.42.0",
    "marked": "^17.0.6",
    "next": "14.2.35",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^17.4.1",
    "esbuild": "^0.28.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
