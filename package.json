{
  "name": "myfitness",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && npm run build:mcp:staged && npm run build:mcp:activate && npm run build:bot",
    "build:staged": "next build && npm run build:mcp:staged && npm run build:bot",
    "build:mcp": "npm run build:mcp:staged && npm run build:mcp:activate",
    "build:mcp:staged": "esbuild src/mcp/server.ts --bundle --platform=node --target=node20 --outfile=dist/mcp/server.staged.cjs --alias:@=./src --external:@prisma/client --external:@modelcontextprotocol/sdk --external:dotenv --define:import.meta.url=importMetaUrl --banner:js=\"const importMetaUrl=require('url').pathToFileURL(__filename).href;\"",
    "build:mcp:activate": "node -e \"const fs=require('fs'),p=require('path'); const src=p.join('dist','mcp','server.staged.cjs'); const dst=p.join('dist','mcp','server.cjs'); if(!fs.existsSync(src)){console.error('build:mcp:activate: staged 파일 없음'); process.exit(1);} fs.renameSync(src,dst); console.log('activated dist/mcp/server.cjs');\"",
    "build:bot": "esbuild src/bot/standalone.ts --bundle --platform=node --target=node20 --outfile=dist/bot/standalone.cjs --alias:@=./src --external:grammy --external:node-cron --external:dotenv --external:@flow-js/garmin-connect --external:@prisma/client/runtime --define:import.meta.url=importMetaUrl --banner:js=\"const importMetaUrl=require('url').pathToFileURL(__filename).href;\"",
    "start": "next start",
    "lint": "eslint src/ --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@flow-js/garmin-connect": "^1.6.16",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.19.3",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.11",
    "grammy": "^1.42.0",
    "isomorphic-dompurify": "^2.30.0",
    "marked": "^17.0.6",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.1",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.10",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "overrides": {
    "axios": "^1.16.0",
    "qs": "^6.15.2",
    "hono": "^4.12.21",
    "fast-uri": "^3.1.2",
    "ip-address": "^10.1.1",
    "brace-expansion@5": "^5.0.6",
    "postcss": "$postcss",
    "form-data": "^4.0.6",
    "esbuild": "$esbuild",
    "@babel/core": "^7.29.6",
    "js-yaml": "^4.2.0"
  }
}
